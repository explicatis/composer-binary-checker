{
    "name": "explicatis/composer-binary-checker",
    "description": "Composer plugin to require the presence of a binary on the target system",
    "type": "composer-plugin",
    "license": "MIT",
    "require": {
        "php": ">=8.2",
        "composer-plugin-api": "^2.0",
        "symfony/process": "^7.0"
    },
    "require-dev": {
        "composer/composer": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "App\\Composer\\": "build/composer/"
        }
    },
    "extra": {
        "class": "App\\Composer\\BinaryChecker",
        "required-binaries": [
            "git"
        ]
    }
}
